#!/usr/bin/env bash
set -euo pipefail

if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    exit 0
fi

if ! git diff --cached --name-only -- gradle.properties | grep -q '^gradle.properties$'; then
    exit 0
fi

old_commit="$(git show HEAD:gradle.properties | sed -n 's/^commit=\([0-9][0-9]*\)$/\1/p' | head -n 1)"
new_commit="$(git show :gradle.properties | sed -n 's/^commit=\([0-9][0-9]*\)$/\1/p' | head -n 1)"

if [[ -z "${old_commit}" || -z "${new_commit}" ]]; then
    exit 0
fi

if (( new_commit < old_commit )); then
    echo "ERROR: gradle.properties commit was lowered (${old_commit} -> ${new_commit})." >&2
    exit 1
fi

if (( new_commit == old_commit )); then
    exit 0
fi

if command -v cmd.exe >/dev/null 2>&1; then
    cmd.exe /c gradlew.bat -q syncBuildNumbersFromCommitCounter
else
    ./gradlew -q syncBuildNumbersFromCommitCounter
fi
git add gradle.properties
